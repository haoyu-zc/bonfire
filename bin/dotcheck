#!/usr/bin/env bash
# =============================================================================
# dotcheck — Show drift between stow packages and $HOME
# Reports: missing files, wrong symlink targets, hardlinks, and non-symlink conflicts.
# Usage: dotcheck [--fix] [--clean]
# =============================================================================
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOTFILES_DIR="$REPO_DIR/dotfiles"

# Source shared logging
SCRIPTS_DIR="$REPO_DIR/scripts"
# shellcheck source=../scripts/_lib.sh
source "$SCRIPTS_DIR/_lib.sh"

# Display helpers unique to dotcheck
ok()       { printf "${C_GREEN}  OK       %s${C_RESET}\n" "$*"; }
missing()  { printf "${C_RED}  MISSING  %s${C_RESET}\n" "$*"; }
wrong()    { printf "${C_YELLOW}  WRONG    %s${C_RESET}\n" "$*"; }
notlink()  { printf "${C_YELLOW}  NOT LINK %s${C_RESET}\n" "$*"; }
hardlink() { printf "${C_YELLOW}  HARDLINK %s${C_RESET}\n" "$*"; }

# =============================================================================
# --clean mode: remove .bak files from stow conflict backups
# =============================================================================
if [[ "${1:-}" == "--clean" ]]; then
    echo "Finding .bak files from stow conflict backups..."
    found=0
    while IFS= read -r -d '' bakfile; do
        echo "  rm $bakfile"
        rm "$bakfile"
        ((found++))
    done < <(find "$HOME" -maxdepth 4 -name "*.bak" -newer "$DOTFILES_DIR" -print0 2>/dev/null)
    echo "$found .bak file(s) removed."
    exit 0
fi

ISSUES=0
OK=0

FIX_MODE=0
if [[ "${1:-}" == "--fix" ]]; then
    FIX_MODE=1
fi

# =============================================================================
# Check each file in each stow package
# =============================================================================
cd "$DOTFILES_DIR"

for pkg_dir in */; do
    pkg="${pkg_dir%/}"
    [[ -z "$pkg" ]] && continue

    printf "\n${C_BOLD}${C_BLUE}[%s]${C_RESET}\n" "$pkg"

    while IFS= read -r -d '' file; do
        # file is like: ./zsh/.zshrc or ./starship/.config/starship.toml
        relpath="${file#./}"      # strip leading ./
        relpath="${relpath#$pkg/}" # strip package prefix -> .zshrc or .config/...

        target="$HOME/$relpath"
        expected="$DOTFILES_DIR/$pkg/$relpath"

        if [[ ! -e "$target" ]] && [[ ! -L "$target" ]]; then
            missing "~/$relpath (expected from $pkg)"
            ((ISSUES++))
            if [[ $FIX_MODE -eq 1 ]]; then
                echo "    Restowing $pkg..."
                if ! stow -t "$HOME" --restow "$pkg"; then
                    echo "    WARNING: stow restow failed for $pkg"
                fi
            fi

        elif [[ -L "$target" ]]; then
            actual="$(readlink -f "$target")"
            if [[ "$actual" == "$expected" ]]; then
                ok "~/$relpath -> $(basename "$expected")"
                ((OK++))
            else
                wrong "~/$relpath -> $actual"
                wrong "   expected -> $expected"
                ((ISSUES++))
            fi

        else
            # Regular file — not managed by stow
            # Check if it's a hardlink to the expected file
            if [[ "$(stat -c %i "$target")" == "$(stat -c %i "$expected")" ]]; then
                hardlink "~/$relpath (hardlink to repo — should be symlink, restow to fix)"
            else
                notlink "~/$relpath (regular file, not a symlink — stow cannot manage)"
            fi
            ((ISSUES++))
            if [[ $FIX_MODE -eq 1 ]]; then
                echo "    Backing up and restowing..."
                mv "$target" "${target}.bak"
                echo "    Backed up to ${target}.bak"
                if ! stow -t "$HOME" --restow "$pkg"; then
                    echo "    WARNING: stow restow failed for $pkg"
                fi
            fi
        fi
    done < <(find "$pkg" -type f -print0)
done

# =============================================================================
# Summary
# =============================================================================
echo ""
printf "${C_BOLD}Summary:${C_RESET} %d correct" "$OK"
[[ $ISSUES -gt 0 ]] && printf ", %d issue(s)" "$ISSUES"
printf "\n\n"

if [[ $ISSUES -eq 0 ]]; then
    printf "${C_GREEN}${C_BOLD}All dotfile symlinks are correct.${C_RESET}\n"
    exit 0
else
    printf "${C_YELLOW}%d issue(s) found.${C_RESET}\n" "$ISSUES"
    if [[ $FIX_MODE -eq 0 ]]; then
        echo "Run 'dotcheck --fix' to attempt automatic fixes."
        echo "Run 'dotcheck --clean' to remove .bak backup files."
        echo "Or run 'dotup' to pull latest and re-stow everything."
    fi
    exit 1
fi
