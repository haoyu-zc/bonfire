#!/usr/bin/env bash
# =============================================================================
# dotadd — Adopt a file from $HOME into a stow package
# Usage: dotadd <stow-package> <file-path>
# Example: dotadd zsh ~/.zshrc
#          dotadd git ~/.gitconfig
#
# Moves the file into the stow package directory and creates a symlink back.
# =============================================================================
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOTFILES_DIR="$REPO_DIR/dotfiles"

# Source shared logging
SCRIPTS_DIR="$REPO_DIR/scripts"
# shellcheck source=../scripts/_lib.sh
source "$SCRIPTS_DIR/_lib.sh"

# =============================================================================
# Usage check
# =============================================================================
if [[ $# -lt 2 ]]; then
    cat <<EOF
Usage: dotadd <stow-package> <file-path>

Moves a file from your home directory into the specified stow package
and restows so a symlink replaces the original file.

Examples:
  dotadd zsh ~/.zshrc
  dotadd git ~/.gitconfig
  dotadd starship ~/.config/starship.toml

Available packages:
EOF
    ls "$DOTFILES_DIR/" | sed 's/^/  /'
    exit 1
fi

PKG="$1"
FILEPATH="$(realpath "$2")"

# =============================================================================
# Validate inputs
# =============================================================================
if [[ ! -e "$FILEPATH" ]]; then
    log_error "File not found: $FILEPATH"
    exit 1
fi

if [[ -L "$FILEPATH" ]]; then
    log_error "$FILEPATH is already a symlink — it may already be managed by stow"
    exit 1
fi

# Compute path relative to $HOME
if [[ "$FILEPATH" != "$HOME"/* ]]; then
    log_error "File must be under \$HOME ($HOME), got: $FILEPATH"
    exit 1
fi

RELPATH="${FILEPATH#$HOME/}"

# =============================================================================
# Package directory
# =============================================================================
PKG_DIR="$DOTFILES_DIR/$PKG"

if [[ ! -d "$PKG_DIR" ]]; then
    log_info "Creating new stow package: $PKG"
    mkdir -p "$PKG_DIR"
fi

DEST="$PKG_DIR/$RELPATH"
DEST_DIR="$(dirname "$DEST")"

# =============================================================================
# Check for conflicts
# =============================================================================
if [[ -e "$DEST" ]]; then
    log_error "Destination already exists in stow package: $DEST"
    exit 1
fi

# =============================================================================
# Move file into stow package
# =============================================================================
log_info "Moving $FILEPATH -> $DEST"
mkdir -p "$DEST_DIR"
mv "$FILEPATH" "$DEST"
log_success "Moved file into '$PKG' package"

# =============================================================================
# Re-stow the package (creates the symlink)
# =============================================================================
log_info "Restowing '$PKG'..."
cd "$DOTFILES_DIR"
if stow -t "$HOME" --restow "$PKG"; then
    log_success "Stowed '$PKG' — symlink created at ~/$RELPATH"
else
    log_warn "Stow encountered a conflict. Rolling back..."
    mv "$DEST" "$FILEPATH"
    log_error "Stow failed — original file restored. Check for conflicts."
    exit 1
fi

# =============================================================================
# Summary
# =============================================================================
echo ""
log_success "Done! ~/$RELPATH is now managed by stow (package: $PKG)"
echo ""
echo "To commit this change:"
echo "  cd $REPO_DIR"
echo "  git add dotfiles/$PKG/$RELPATH"
echo "  git commit -m 'dotfiles: add $RELPATH to $PKG'"
