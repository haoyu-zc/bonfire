#!/usr/bin/env bash
# =============================================================================
# dotup — Pull latest changes and re-stow all dotfile packages
# Usage: dotup [--full]
#   --full   Full sync: re-run all install scripts + mise prune (delegates to dotsync)
# =============================================================================
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [[ "${1:-}" == "--full" ]]; then
    exec "$REPO_DIR/bin/dotsync"
fi

# Source shared logging
SCRIPTS_DIR="$REPO_DIR/scripts"
# shellcheck source=../scripts/_lib.sh
source "$SCRIPTS_DIR/_lib.sh"

# =============================================================================
# Pull latest changes
# =============================================================================
log_info "Pulling latest changes from remote..."
cd "$REPO_DIR"

if git remote get-url origin &>/dev/null; then
    if ! git pull --rebase; then
        if [[ -d "$REPO_DIR/.git/rebase-merge" || -d "$REPO_DIR/.git/rebase-apply" ]]; then
            git rebase --abort
            log_warn "Rebase conflict detected — aborted. Resolve manually with: git pull --rebase"
        else
            log_warn "git pull failed — check network or repo state"
        fi
    else
        log_success "Repository up to date"
    fi
else
    log_warn "No remote configured — skipping git pull"
fi

# =============================================================================
# Re-stow all dotfile packages
# =============================================================================
log_info "Re-stowing dotfiles..."
cd "$REPO_DIR/dotfiles"
ERRORS=0
STOWED=0

for pkg_dir in */; do
    pkg="${pkg_dir%/}"
    [[ -z "$pkg" ]] && continue

    if stow -t "$HOME" --restow "$pkg" 2>&1; then
        log_success "$pkg"
        STOWED=$(( STOWED + 1 ))
    else
        log_warn "$pkg (conflict — run 'stow -t \$HOME -v --restow $pkg' to debug)"
        ERRORS=$(( ERRORS + 1 ))
    fi
done

# =============================================================================
# Update mise tools
# =============================================================================
log_info "Running mise install..."
if command -v mise &>/dev/null; then
    mise install
    log_success "mise tools up to date"
else
    log_warn "mise not found — skipping"
fi

# =============================================================================
# Summary
# =============================================================================
echo ""
printf "${C_BOLD}Summary:${C_RESET} %d stowed" "$STOWED"
[[ $ERRORS -gt 0 ]] && printf ", %d conflict(s)" "$ERRORS"
printf "\n"

if [[ $ERRORS -gt 0 ]]; then
    log_warn "Run 'dotcheck' to see all issues"
fi

echo ""
echo "Done. Restart your shell to pick up changes."
